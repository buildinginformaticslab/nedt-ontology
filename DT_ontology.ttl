#############################################################
#  v1.1 EXTENSIONS — competency-question driven additions
#  ----------------------------------------------------------
#  18 new classes + 14 new properties introduced to answer
#  CQ1-CQ12 (see DT_ontology_paper.md §8).
#
#  Refinement vs first draft:
#    * nedt:UptakeFraction collapsed into the datatype property
#      nedt:uptakeValue on nedt:ScenarioParameter (flatter ABox).
#    * nedt:EndUseContribution subclassed under the existing
#      nedt:ContribRank instead of a sibling class.
#    * nedt:evaluatesCounty / nedt:evaluatesYear domain moved
#      from nedt:KPI to nedt:KPIValue to match nedt:derivedUnder
#      (scope attaches to the measurement, not the definition).
#
#  Provenance (CQ12) reuses PROV-O directly; nedt:DTRun,
#  nedt:SensitivityRun and nedt:ScenarioAssumption are typing
#  subclasses only.
#############################################################

# ---- Typed archetype descriptors (CQ1) -------------------
nedt:BERRating            a owl:Class ; rdfs:subClassOf nedt:ArchetypeDescriptor ;
    rdfs:label "BER Rating"@en ;
    rdfs:comment "Building Energy Rating letter (A1-G) assigned to a dwelling archetype by SEAI."@en .
nedt:DwellingType         a owl:Class ; rdfs:subClassOf nedt:ArchetypeDescriptor ;
    rdfs:label "Dwelling Type"@en ;
    rdfs:comment "Structural dwelling type: detached, semi-detached, terrace, end-of-terrace, apartment."@en .
nedt:ConstructionPeriod   a owl:Class ; rdfs:subClassOf nedt:ArchetypeDescriptor ;
    rdfs:label "Construction Period"@en ;
    rdfs:comment "CSO / SEAI construction-period band (pre-1919, 1919-1945, 1946-1970, 1971-1990, 1991-2010, post-2011)."@en .

# ---- End-use load decomposition (CQ2, CQ4, CQ6) ----------
nedt:EndUseLoad           a owl:Class ; rdfs:subClassOf nedt:EnergyLoad ;
    rdfs:label "End-Use Load"@en ;
    rdfs:comment "A load component tagged by end-use (space_heat, dhw, appliance, lighting, cooking, ev, hp_replace). Enables decomposition of the archetype profile into interpretable components."@en .

# ---- Scenario parameterisation (CQ3) ---------------------
nedt:ScenarioParameter    a owl:Class ;
    rdfs:label "Scenario Parameter"@en ;
    rdfs:comment "One numeric parameter of a scenario (HP uptake fraction, EV uptake fraction, PV kWp) bound to a single archetype and year. Value carried by nedt:uptakeValue."@en .

# ---- LV aggregation (CQ5) --------------------------------
nedt:LVAggregation        a owl:Class ; rdfs:subClassOf ssn:Procedure ;
    rdfs:label "LV Aggregation Procedure"@en ;
    rdfs:comment "Procedure that sums archetype-level hourly load to the LV-station level via the hull-polygon assignment."@en .

# ---- Overload events & attribution (CQ6, CQ10) -----------
nedt:OverloadEvent        a owl:Class ;
    rdfs:label "Overload Event"@en ;
    rdfs:comment "Single-hour exceedance of an LV station's nameplate capacity in a scenario run."@en .
nedt:EndUseContribution   a owl:Class ; rdfs:subClassOf nedt:ContribRank ;
    rdfs:label "End-Use Contribution"@en ;
    rdfs:comment "Share of an overload event attributable to a specific end-use (HP, EV, PV reverse-flow, baseline)."@en .

# ---- PV self-consumption KPIs (CQ7) ----------------------
nedt:SelfConsumptionRatio a owl:Class ; rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "Self-Consumption Ratio"@en ;
    rdfs:comment "Annual PV self-consumption as a fraction (0-1) of generation used on-site."@en .
nedt:ExportedEnergy       a owl:Class ; rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "Exported Energy"@en ;
    rdfs:comment "Annual PV energy exported to the grid (kWh)."@en .
nedt:ReversePowerFlowHour a owl:Class ; rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "Reverse Power-Flow Hour"@en ;
    rdfs:comment "An hour with negative net flow at the LV transformer (local PV generation exceeds local consumption)."@en .

# ---- County / national KPI scope (CQ8, CQ9, CQ10) --------
nedt:CoincidentPeak       a owl:Class ; rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "Coincident Peak"@en ;
    rdfs:comment "County- or national-level coincident electrical peak (MW) with its time-stamp."@en .
nedt:CountyKPI            a owl:Class ; rdfs:subClassOf nedt:KPI ;
    rdfs:label "County KPI"@en ;
    rdfs:comment "A KPI definition whose values are always scoped to one county (via nedt:evaluatesCounty on the KPIValue)."@en .
nedt:NationalKPI          a owl:Class ; rdfs:subClassOf nedt:KPI ;
    rdfs:label "National KPI"@en ;
    rdfs:comment "A KPI definition whose values are aggregated across all 26 counties."@en .
nedt:ReinforcementNeed    a owl:Class ; rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "Reinforcement Need"@en ;
    rdfs:comment "Flag value carrying first-breach year and annual breach-hours for a station or county."@en .

# ---- Provenance typing (CQ12) ----------------------------
nedt:DTRun                a owl:Class ; rdfs:subClassOf prov:Activity ;
    rdfs:label "DT Run"@en ;
    rdfs:comment "A single execution of the digital-twin notebook that produces a bundle of KPIValues. Uses prov:used / prov:generated / prov:wasDerivedFrom directly."@en .
nedt:SensitivityRun       a owl:Class ; rdfs:subClassOf prov:Activity ;
    rdfs:label "Sensitivity Run"@en ;
    rdfs:comment "A parameter-sweep execution that ranks scenario parameters by their marginal effect on county peak and CO2."@en .
nedt:ScenarioAssumption   a owl:Class ; rdfs:subClassOf prov:Entity ;
    rdfs:label "Scenario Assumption"@en ;
    rdfs:comment "A written or sourced assumption underpinning a scenario parameter (CAP, SEAI, internal expert judgement)."@en .

# ---- New properties --------------------------------------
nedt:endUse               a owl:DatatypeProperty ; rdfs:domain nedt:EndUseLoad ; rdfs:range xsd:string ;
    rdfs:label "end-use"@en ;
    rdfs:comment "Enumerated end-use tag: space_heat | dhw | appliance | lighting | cooking | ev | hp_replace."@en .
nedt:hasScenarioParameter a owl:ObjectProperty ; rdfs:domain nedt:Scenario ; rdfs:range nedt:ScenarioParameter ;
    rdfs:label "has scenario parameter"@en .
nedt:forArchetype         a owl:ObjectProperty ; rdfs:domain nedt:ScenarioParameter ; rdfs:range nedt:Archetype ;
    rdfs:label "for archetype"@en .
nedt:forYear              a owl:DatatypeProperty ; rdfs:domain nedt:ScenarioParameter ; rdfs:range xsd:gYear ;
    rdfs:label "for year"@en .
nedt:uptakeValue          a owl:DatatypeProperty ; rdfs:domain nedt:ScenarioParameter ; rdfs:range xsd:decimal ;
    rdfs:label "uptake value"@en ;
    rdfs:comment "Numeric fraction in [0,1] for HP/EV uptake, or kWp for PV."@en .
nedt:occursAt             a owl:DatatypeProperty ; rdfs:domain nedt:OverloadEvent ; rdfs:range xsd:dateTime ;
    rdfs:label "occurs at"@en .
nedt:overloadMagnitude_kW a owl:DatatypeProperty ; rdfs:domain nedt:OverloadEvent ; rdfs:range xsd:decimal ;
    rdfs:label "overload magnitude (kW)"@en .
nedt:attributedToEndUse   a owl:ObjectProperty ; rdfs:domain nedt:EndUseContribution ; rdfs:range nedt:EndUseLoad ;
    rdfs:label "attributed to end-use"@en .
nedt:contributionPercent  a owl:DatatypeProperty ; rdfs:domain nedt:EndUseContribution ; rdfs:range xsd:decimal ;
    rdfs:label "contribution percent"@en ;
    rdfs:comment "Share 0-100 of the overload attributable to this end-use."@en .
nedt:evaluatesCounty      a owl:ObjectProperty ; rdfs:domain nedt:KPIValue ; rdfs:range nedt:County ;
    rdfs:label "evaluates county"@en .
nedt:evaluatesYear        a owl:DatatypeProperty ; rdfs:domain nedt:KPIValue ; rdfs:range xsd:gYear ;
    rdfs:label "evaluates year"@en .
nedt:derivedUnder         a owl:ObjectProperty ; rdfs:domain nedt:KPIValue ; rdfs:range nedt:Scenario ;
    rdfs:label "derived under scenario"@en .
nedt:firstBreachYear      a owl:DatatypeProperty ; rdfs:domain nedt:ReinforcementNeed ; rdfs:range xsd:gYear ;
    rdfs:label "first breach year"@en .
nedt:breachHours          a owl:DatatypeProperty ; rdfs:domain nedt:ReinforcementNeed ; rdfs:range xsd:integer ;
    rdfs:label "breach hours per year"@en .

# ---- Layer annotations (all DT-model-extension) ----------
nedt:BERRating            nedt:layer "DT-model-extension"@en .
nedt:DwellingType         nedt:layer "DT-model-extension"@en .
nedt:ConstructionPeriod   nedt:layer "DT-model-extension"@en .
nedt:EndUseLoad           nedt:layer "DT-model-extension"@en .
nedt:ScenarioParameter    nedt:layer "DT-model-extension"@en .
nedt:LVAggregation        nedt:layer "DT-model-extension"@en .
nedt:OverloadEvent        nedt:layer "DT-model-extension"@en .
nedt:EndUseContribution   nedt:layer "DT-model-extension"@en .
nedt:SelfConsumptionRatio nedt:layer "DT-model-extension"@en .
nedt:ExportedEnergy       nedt:layer "DT-model-extension"@en .
nedt:ReversePowerFlowHour nedt:layer "DT-model-extension"@en .
nedt:CoincidentPeak       nedt:layer "DT-model-extension"@en .
nedt:CountyKPI            nedt:layer "DT-model-extension"@en .
nedt:NationalKPI          nedt:layer "DT-model-extension"@en .
nedt:ReinforcementNeed    nedt:layer "DT-model-extension"@en .
nedt:DTRun                nedt:layer "DT-model-extension"@en .
nedt:SensitivityRun       nedt:layer "DT-model-extension"@en .
nedt:ScenarioAssumption   nedt:layer "DT-model-extension"@en .

#############################################################
#  v1.2.0 — Heat-density & flexibility extension (CQ13–CQ15)
#  ----------------------------------------------------------
#  Added 2026-04-22 to answer three supervisor-priority CQs:
#     CQ13  district-heating viability
#     CQ14  group / community heating candidates
#     CQ15  LV-node flexibility & demand-response capacity
#############################################################

# ---- Classes ---------------------------------------------
nedt:HeatDensity a owl:Class ;
    rdfs:subClassOf sosa:ObservableProperty ;
    rdfs:label "Heat demand density"@en ;
    rdfs:comment "Annual thermal demand per unit floor or land area (kWh·m⁻²·yr⁻¹) evaluated at a grid cell, SA cluster or dwelling group."@en .

nedt:ThermalDemandCluster a owl:Class ;
    rdfs:label "Thermal-demand cluster"@en ;
    rdfs:comment "A contiguous group of archetypes / cells whose aggregated HeatDensity exceeds a threshold, produced by the DH-viability procedure."@en ;
    rdfs:seeAlso bot:Zone .

nedt:DHViabilityKPI a owl:Class ;
    rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "District-heating viability KPI"@en ;
    rdfs:comment "Carries the boolean viability verdict and the underlying heat density for one cluster / county / scenario / year."@en .

nedt:GroupHeatingCandidate a owl:Class ;
    rdfs:subClassOf nedt:ThermalDemandCluster ;
    rdfs:label "Group / community heating candidate"@en ;
    rdfs:comment "A ThermalDemandCluster in the 50–120 kWh·m⁻²·yr⁻¹ band whose compactness and dwelling-mix make it suitable for a shared-plant scheme."@en .

nedt:FlexibleLoad a owl:Class ;
    rdfs:subClassOf nedt:EndUseLoad ;
    rdfs:label "Flexible load"@en ;
    rdfs:comment "The subset of an EndUseLoad whose timing can be shifted inside a demand-response window (typically HP, EV and HP_replace end-uses)."@en .

nedt:FlexibilityKPI a owl:Class ;
    rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "LV-node flexibility KPI"@en ;
    rdfs:comment "Shiftable kW at an LV station under a stated demand-response window and scenario / year."@en .

nedt:DemandResponseCapacity a owl:Class ;
    rdfs:subClassOf nedt:KPIValue ;
    rdfs:label "Demand-response capacity"@en ;
    rdfs:comment "Head-room (kW) available to a DR programme at an LV node after accounting for comfort and SOC constraints."@en .

# ---- Properties ------------------------------------------
nedt:heatDemand_kWh_per_m2_yr a owl:DatatypeProperty ;
    rdfs:domain nedt:HeatDensity ; rdfs:range xsd:decimal ;
    rdfs:label "heat demand (kWh/m²·yr)"@en .

nedt:viabilityThreshold_kWh_per_m2_yr a owl:DatatypeProperty ;
    rdfs:domain nedt:DHViabilityKPI ; rdfs:range xsd:decimal ;
    rdfs:label "DH viability threshold (kWh/m²·yr)"@en .

nedt:isDHViable a owl:DatatypeProperty ;
    rdfs:domain nedt:DHViabilityKPI ; rdfs:range xsd:boolean ;
    rdfs:label "is DH viable"@en .

nedt:clusterCompactness a owl:DatatypeProperty ;
    rdfs:domain nedt:ThermalDemandCluster ; rdfs:range xsd:decimal ;
    rdfs:label "cluster compactness ratio (0–1)"@en .

nedt:flexibilityKW a owl:DatatypeProperty ;
    rdfs:domain nedt:FlexibilityKPI ; rdfs:range xsd:decimal ;
    rdfs:label "shiftable load (kW)"@en .

nedt:controllableFraction a owl:DatatypeProperty ;
    rdfs:domain nedt:FlexibleLoad ; rdfs:range xsd:decimal ;
    rdfs:label "controllable fraction (0–1)"@en .

# ---- Layer annotations (all DT-model-extension) ----------
nedt:HeatDensity              nedt:layer "DT-model-extension"@en .
nedt:ThermalDemandCluster     nedt:layer "DT-model-extension"@en .
nedt:DHViabilityKPI           nedt:layer "DT-model-extension"@en .
nedt:GroupHeatingCandidate    nedt:layer "DT-model-extension"@en .
nedt:FlexibleLoad             nedt:layer "DT-model-extension"@en .
nedt:FlexibilityKPI           nedt:layer "DT-model-extension"@en .
nedt:DemandResponseCapacity   nedt:layer "DT-model-extension"@en .


#############################################################
#  MODULE 11 — IEC CIM Alignment  (NEW, v1.3)
#
#  Terminological alignment between the NEDT ontology and the
#  IEC Common Information Model (CIM):
#    - IEC 61970-301  (Core / Wires / Meas / Generation — EMS)
#    - IEC 61968      (Common, Assets, Metering — DMS extensions)
#
#  Namespace note: uses the CIM100 namespace
#  (http://iec.ch/TC57/CIM100#) as published for CGMES 3.0
#  (IEC 61970-600-2). If aligning against CGMES 2.4.15 instead,
#  substitute http://iec.ch/TC57/2013/CIM-schema-cim16#.
#
#  Scope and honesty statement: this module asserts *vocabulary
#  alignment* (which CIM classes correspond to which nedt: classes).
#  It does NOT claim CGMES profile conformance or IEC 61968
#  message-interface compliance: NEDT does not exchange CIM RDF/XML
#  instance data. Mappings use rdfs:subClassOf only where the nedt
#  class is a genuine specialisation; correspondences that differ
#  in modelling perspective (observation value vs. equipment
#  attribute) use rdfs:seeAlso plus an explanatory note, so that
#  no over-strong equivalence is asserted.
#############################################################

# ---- 11.1  Network assets & containment (IEC 61970-301 Core) ----

# An ESB LV station is a distribution substation (typically a single
# pole- or ground-mounted transformer). Subclass, not equivalence:
# cim:Substation covers all voltage levels; nedt:LVStation is the
# 400 V / MV-LV special case.
nedt:LVStation
    rdfs:subClassOf cim:Substation ;
    rdfs:seeAlso    cim:PowerTransformer ;
    skos:note "One-to-one with its MV/LV transformer in the ESB dataset, so the station also stands proxy for cim:PowerTransformer; the station's designed kVA is the transformer's cim:PowerTransformerEnd.ratedS."@en .

# County as the geographic container of substations.
nedt:County
    rdfs:seeAlso cim:SubGeographicalRegion ;
    skos:note "Plays the role of cim:SubGeographicalRegion (the CIM container of cim:Substation via the SubGeographicalRegion.Substations association), but is an Irish administrative unit (OSi), not a CIM-modelled region."@en .

# nedt:contains (County → LVStation) corresponds to the CIM
# association SubGeographicalRegion.Substations.
nedt:contains
    rdfs:seeAlso cim:SubGeographicalRegion.Substations .

# ---- 11.2  Ratings, loads & measurements (61970-301 Wires/Meas) ----

# Station capacity: in CIM the nameplate rating is the datatype
# attribute cim:PowerTransformerEnd.ratedS (apparent power, kVA),
# and the planning limit is a cim:ApparentPowerLimit within an
# OperationalLimitSet. nedt models it as an SSN observation value,
# so seeAlso rather than subclass/equivalence.
nedt:StationCapacity
    rdfs:seeAlso cim:ApparentPowerLimit , cim:PowerTransformerEnd.ratedS ;
    skos:note "designed_kva (and its ambient-corrected variant designed_kva_eff per IEC 60076-2) corresponds to cim:PowerTransformerEnd.ratedS; as a planning limit it corresponds to cim:ApparentPowerLimit."@en .

# Electric load: CIM models the *consuming equipment*
# (cim:EnergyConsumer, with attributes p and q); nedt models the
# *demand quantity* itself. Different perspectives — seeAlso.
nedt:ElectricLoad
    rdfs:seeAlso cim:EnergyConsumer ;
    skos:note "nedt models the aggregate demand quantity; in CIM the demand lives as EnergyConsumer.p / EnergyConsumer.q on the consuming-equipment class."@en .

# Aggregate station load as a (computed) measurement value at the
# substation — CIM Meas package.
nedt:StationLoad
    rdfs:seeAlso cim:Analog , cim:AnalogValue ;
    skos:note "Hourly aggregated kVA at the station; corresponds to a cim:AnalogValue of a cim:Analog measurement on the transformer LV terminal. In NEDT it is model-derived, not telemetered."@en .

# Hourly profiles: CIM represents time-series either as schedules
# (61970-301 cim:RegularIntervalSchedule) or metering interval data
# (61968-9 cim:IntervalBlock / cim:IntervalReading).
nedt:HourlyProfile
    rdfs:seeAlso cim:RegularIntervalSchedule , cim:IntervalBlock ;
    skos:note "8760-hour demand/generation shapes; schedule-like (RegularIntervalSchedule) rather than metered readings."@en .

# ---- 11.3  Service areas & customer connection (IEC 61968) ----

# CIM has per-premises service points (61968-9 cim:UsagePoint,
# 61968-8 cim:ServiceLocation) but no aggregate service-territory
# polygon per substation. The hull polygon is therefore an NEDT
# contribution; the nearest CIM anchors are noted.
nedt:HullPolygon
    rdfs:seeAlso cim:Location ;
    skos:note "Station service-area polygon (weighted-Voronoi / concave hull). CIM 61968 models per-customer ServiceLocation and asset Location/PositionPoint geometry, but has no aggregate substation service territory — gap filled by NEDT."@en .

# Building-to-station assignment: the role played by cim:UsagePoint
# (the point where a premises connects to the network).
nedt:BuildingShare
    rdfs:seeAlso cim:UsagePoint ;
    skos:note "Fractional assignment of buildings to a station; the disaggregated equivalent of enumerating the station's cim:UsagePoint connections."@en .

# ---- 11.4  DER & flexibility (61970-301 Generation, 61968-9) ----

nedt:PVSystem
    rdfs:seeAlso cim:PhotoVoltaicUnit ;
    skos:note "Dwelling rooftop PV, kWp-binned; corresponds to cim:PhotoVoltaicUnit (a cim:PowerElectronicsUnit) in CIM100/CGMES 3.0."@en .

nedt:DemandResponseCapacity
    rdfs:seeAlso cim:DemandResponseProgram ;
    skos:note "Shiftable kW at the LV node; CIM 61968-9 models the programme construct (DemandResponseProgram + controls), not the aggregate capacity quantity."@en .

# ---- 11.5  Explicit gaps — NEDT contributions beyond CIM scope ----
# Declared deliberately so reviewers see the boundary of the claim:
# CIM (61970/61968) has no vocabulary for scenario-simulated
# overload analytics. These classes are original NEDT contributions:
#
#   nedt:Utilisation, nedt:UtilisationStatus  — load/capacity bands
#   nedt:OverloadEvent, nedt:OverloadedStation (beyond its LVStation
#       superclass), nedt:OverloadAttribution, nedt:DominantDriver
#   nedt:Scenario, nedt:HPScenario, nedt:EVScenario, nedt:StationTransition
#   nedt:CO2Emission
#
# The nearest CIM construct for utilisation banding is an
# OperationalLimit exceedance, noted below for completeness.

nedt:Utilisation
    rdfs:seeAlso cim:OperationalLimitSet ;
    skos:note "Peak load / effective rating ratio; CIM expresses the limit (OperationalLimitSet/ApparentPowerLimit) but not the computed utilisation ratio or its status bands — gap filled by NEDT."@en .
