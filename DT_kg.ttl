inst:NexsysProfile_Terraced_C_1_gasboiler a nedt:NexsysProfile ;
    rdfs:label "Nexsys·Terraced_C_1_gasboiler" ;
    nedt:sourceFile "Nexsys data_to divyanshu/modified_V1H_results_dynamic/Terraced_C_1_gasboiler.csv" .

inst:NexsysProfile_Terraced_D_1_Oilboiler a nedt:NexsysProfile ;
