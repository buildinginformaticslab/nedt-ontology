    nedt:sourceFile "Nexsys data_to divyanshu/modified_V1H_results_dynamic/Detached_C_1_Oilboiler.csv" .

inst:NexsysProfile_Detached_C_1_gasboiler a nedt:NexsysProfile ;
    rdfs:label "Nexsys·Detached_C_1_gasboiler" ;
    nedt:sourceFile "Nexsys data_to divyanshu/modified_V1H_results_dynamic/Detached_C_1_gasboiler.csv" .

