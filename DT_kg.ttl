inst:PVAdoptionScenario_AsIs_2025 a nedt:PVAdoptionScenario ;
    rdfs:label "AS-IS PV adoption (SEAI 2018–2025 cumulative)" ;
    nedt:hasCapacityMix inst:PVCapacityMix_IE2017 .

inst:PVReferenceShape_IE_mean a nedt:PVReferenceShape ;
    rdfs:label "Ireland mean PV reference shape (1 kWp, 8760h)" ;
    nedt:annualYield_kWh_per_kWp 1095.0 .

nedt:BERFallbackRule a owl:Class ;
    rdfs:label "BER Fallback Rule"@en ;
    rdfs:comment "Substitution rule used when no direct profile exists for a BER letter (e.g., F/G folded into E)." ;
    nedt:layer "DT-model-extension"@en .

nedt:BuildingShare a owl:Class ;
    rdfs:label "Building Share"@en ;
    rdfs:seeAlso saragon:hasServiceArea ;
    nedt:layer "core-KG-framework"@en .

nedt:CO2Emission a owl:Class ;
    rdfs:label "CO2 Emission"@en ;
    rdfs:subClassOf ssn:ObservationValue ;
    nedt:layer "DT-model-extension"@en .

nedt:ColourPalette a owl:Class ;
    rdfs:label "Colour Palette"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:DeltaSeries a owl:Class ;
    rdfs:label "Delta Series"@en ;
    rdfs:comment "Scenario − baseline hourly time series; feeds visualisation and attribution." ;
    rdfs:subClassOf nedt:HourlyProfile ;
    nedt:layer "DT-model-extension"@en .

nedt:DominantDriver a owl:Class ;
    rdfs:label "Dominant Driver"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:EVMode a owl:Class ;
    rdfs:label "EV Charging Mode"@en ;
    rdfs:comment "Controlled charging strategy: uncontrolled / tier-3 / tier-4 / V1H / V2H." ;
    nedt:layer "DT-model-extension"@en .

nedt:GeoLocation a owl:Class ;
    rdfs:label "Geo Location"@en ;
    rdfs:seeAlso geo:Feature ;
    rdfs:subClassOf geo:Feature ;
    nedt:layer "core-KG-framework"@en .

nedt:HPScenario a owl:Class ;
    rdfs:label "Heat-Pump Scenario"@en ;
    rdfs:subClassOf nedt:Scenario ;
    nedt:layer "DT-model-extension"@en .

nedt:HPTransition a owl:Class ;
    rdfs:label "Heat-Pump Transition"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:HeatDensity a owl:Class ;
    rdfs:label "Heat Density"@en ;
    rdfs:comment "kWh/m² or equivalent per spatial cell; supports district-heating feasibility analysis." ;
    rdfs:subClassOf ssn:ObservationValue ;
    nedt:layer "DT-model-extension"@en .

nedt:HeatFuelComponent a owl:Class ;
    rdfs:label "Heat Fuel Component"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:HeatLoad a owl:Class ;
    rdfs:label "Heat Load"@en ;
    rdfs:subClassOf nedt:EnergyLoad ;
    nedt:layer "DT-model-extension"@en .

nedt:HullPolygon a owl:Class ;
    rdfs:label "Hull Polygon"@en ;
    rdfs:seeAlso geo:Geometry ;
    rdfs:subClassOf geo:Geometry ;
    nedt:layer "core-KG-framework"@en .

nedt:KPIEvaluatedObject a owl:Class ;
    rdfs:label "KPI Evaluated Object"@en ;
    rdfs:comment "Anchor class for whatever a KPI evaluates: County, LV Station, Archetype, or Scenario." ;
    nedt:layer "DT-model-extension"@en .

nedt:LargestRemainderAlloc a owl:Class ;
    rdfs:label "Largest-Remainder Allocation"@en ;
    rdfs:subClassOf ssn:Procedure ;
    nedt:layer "DT-model-extension"@en .

nedt:NetLoad a owl:Class ;
    rdfs:label "Net Load"@en ;
    rdfs:comment "Per-dwelling hourly load after PV netting, clamped at zero (no grid export assumed)." ;
    rdfs:subClassOf nedt:ElectricLoad ;
    nedt:layer "DT-model-extension"@en .

nedt:NettingProcedure a owl:Class ;
    rdfs:label "PV Netting Procedure"@en ;
    rdfs:subClassOf ssn:Procedure ;
    nedt:layer "DT-model-extension"@en .

nedt:PVReferenceShape a owl:Class ;
    rdfs:label "PV Reference Shape"@en ;
    rdfs:comment "Normalised 1 kWp shape derived as the mean of all Nexsys PV columns after peak/0.85 normalisation (~1095 kWh/yr)." ;
    rdfs:subClassOf nedt:PVGenerationProfile ;
    nedt:layer "DT-model-extension"@en .

nedt:ReportSection a owl:Class ;
    rdfs:label "Report Section"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:Stakeholder a owl:Class ;
    rdfs:label "Stakeholder"@en ;
    rdfs:comment "An actor that defines performance goals for the digital twin (e.g., DSO, council, policy maker)." ;
    nedt:layer "core-KG-framework"@en .

nedt:StationCapacity a owl:Class ;
    rdfs:label "Station Capacity"@en ;
    rdfs:subClassOf ssn:ObservationValue ;
    nedt:layer "DT-model-extension"@en .

nedt:StationLoad a owl:Class ;
    rdfs:label "Station Load"@en ;
    rdfs:subClassOf nedt:ElectricLoad ;
    nedt:layer "DT-model-extension"@en .

nedt:StrategicKPI a owl:Class ;
    rdfs:label "Strategic KPI"@en ;
    rdfs:subClassOf nedt:KPI ;
    nedt:layer "DT-model-extension"@en .

nedt:Tariff a owl:Class ;
    rdfs:label "Tariff"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:TransitionKey a owl:Class ;
    rdfs:label "Transition Key"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:UtilisationStatus a owl:Class ;
    rdfs:label "Utilisation Status"@en ;
    rdfs:comment "Green / yellow / red-maroon exceedance band." ;
    nedt:layer "DT-model-extension"@en .

