nedt:ChartJSChart a owl:Class ;
    rdfs:label "Chart.js Chart"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:ContribRank a owl:Class ;
    rdfs:label "Contribution Rank"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:CountySummary a owl:Class ;
    rdfs:label "County Summary"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:DatumSource a owl:Class ;
    rdfs:label "Datum Source"@en ;
    rdfs:comment "A bound input dataset (CSV, parquet, GeoJSON, shapefile) that provides observations to a KPI calculation." ;
    nedt:layer "core-KG-framework"@en .

nedt:EVScenario a owl:Class ;
    rdfs:label "EV Scenario"@en ;
    rdfs:subClassOf nedt:Scenario ;
    nedt:layer "DT-model-extension"@en .

nedt:EndUseContribution a owl:Class ;
    rdfs:label "End-Use Contribution"@en ;
    rdfs:comment "Share of an overload event attributable to a specific end-use (HP, EV, PV reverse-flow, baseline)."@en ;
    rdfs:subClassOf nedt:ContribRank ;
    nedt:layer "DT-model-extension"@en .

nedt:EndUseLoad a owl:Class ;
    rdfs:label "End-Use Load"@en ;
    rdfs:comment "A load component tagged by end-use (space_heat, dhw, appliance, lighting, cooking, ev, hp_replace). Enables decomposition of the archetype profile into interpretable components."@en ;
    rdfs:subClassOf nedt:EnergyLoad ;
    nedt:layer "DT-model-extension"@en .

nedt:HeatDensityGDF a owl:Class ;
    rdfs:label "Heat Density GeoDataFrame"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:KPICalculation a owl:Class ;
    rdfs:label "KPI Calculation"@en ;
    rdfs:subClassOf ssn:Procedure ;
    nedt:layer "DT-model-extension"@en .

nedt:OverloadEvent a owl:Class ;
    rdfs:label "Overload Event"@en ;
    rdfs:comment "Single-hour exceedance of an LV station's nameplate capacity in a scenario run."@en ;
    nedt:layer "DT-model-extension"@en .

nedt:PVCapacityMix a owl:Class ;
    rdfs:label "PV Capacity Mix"@en ;
    rdfs:comment "Probability distribution over PVCapacityBins. Default Irish 2017 reference: 10/47/23/6/11/3%." ;
    nedt:layer "DT-model-extension"@en .

nedt:PVGenerationProfile a owl:Class ;
    rdfs:label "PV Generation Profile"@en ;
    rdfs:comment "Hourly kW generation; empirically collapses to one weather-driven reference shape across archetypes (cosine similarity ≥ 0.96)." ;
    rdfs:subClassOf nedt:HourlyProfile ;
    nedt:layer "DT-model-extension"@en .

nedt:PerformanceGoal a owl:Class ;
    rdfs:label "Performance Goal"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:ProfileKey a owl:Class ;
    rdfs:label "Profile Key"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:ReinforcementNeed a owl:Class ;
    rdfs:label "Reinforcement Need"@en ;
    rdfs:comment "Flag value carrying first-breach year and annual breach-hours for a station or county."@en ;
    rdfs:subClassOf nedt:KPIValue ;
    nedt:layer "DT-model-extension"@en .

nedt:RiskTable a owl:Class ;
    rdfs:label "Risk Table"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:TopTransitions a owl:Class ;
    rdfs:label "Top Transitions"@en ;
    nedt:layer "DT-model-extension"@en .

nedt:TransitionLedger a owl:Class ;
    rdfs:label "Transition Ledger"@en ;
    rdfs:comment "Record of how dwellings migrate between heating systems or BER levels under a scenario." ;
    nedt:layer "DT-model-extension"@en .

nedt:Utilisation a owl:Class ;
    rdfs:label "Utilisation"@en ;
    rdfs:subClassOf ssn:ObservationValue ;
    nedt:layer "DT-model-extension"@en .

