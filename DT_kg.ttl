@prefix bot: <https://w3id.org/bot#> .
@prefix nedt: <https://example.org/nedt#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix gd: <https://example.org/geodirectory#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix inst: <https://example.org/nedt/inst/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix osi: <https://example.org/osi#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix saragon: <https://w3id.org/saragon#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/nedt> a owl:Ontology ;
    dct:creator "Divyanshu Sood" ;
    dct:description "An OWL ontology describing building archetypes, hourly energy profiles, LV-network attribution, scenarios (including rooftop-PV adoption), KPI evaluation and visualisation components of a county-scale residential energy digital twin for Ireland."@en ;
    dct:issued "2026-04-20"^^xsd:date ;
    dct:modified "2026-04-21"^^xsd:date ;
    dct:title "National Energy Digital Twin (NEDT) Ontology"@en ;
    rdfs:seeAlso om:,
        <https://www.w3.org/2006/time>,
        <https://www.w3.org/ns/ssn/> ;
    owl:versionInfo "1.1.0" ;
    skos:note "Structurally aligned with Li et al. (2019) EM-KPI ontology and reuses SSN/SOSA for observations, OWL-Time for temporal intervals, OM-2 for units and GeoSPARQL for spatial geometries."@en .

nedt:BERRating a owl:Class ;
    rdfs:label "BER Rating"@en ;
    rdfs:comment "Building Energy Rating letter (A1-G) assigned to a dwelling archetype by SEAI."@en ;
    rdfs:subClassOf nedt:ArchetypeDescriptor ;
    nedt:layer "DT-model-extension"@en .

nedt:CoincidentPeak a owl:Class ;
    rdfs:label "Coincident Peak"@en ;
    rdfs:comment "County- or national-level coincident electrical peak (MW) with its time-stamp."@en ;
    rdfs:subClassOf nedt:KPIValue ;
    nedt:layer "DT-model-extension"@en .

nedt:ConstructionPeriod a owl:Class ;
    rdfs:label "Construction Period"@en ;
    rdfs:comment "CSO / SEAI construction-period band (pre-1919, 1919-1945, 1946-1970, 1971-1990, 1991-2010, post-2011)."@en ;
    rdfs:subClassOf nedt:ArchetypeDescriptor ;
    nedt:layer "DT-model-extension"@en .

nedt:CountyKPI a owl:Class ;
    rdfs:label "County KPI"@en ;
    rdfs:comment "A KPI definition whose values are always scoped to one county (via nedt:evaluatesCounty on the KPIValue)."@en ;
    rdfs:subClassOf nedt:KPI ;
    nedt:layer "DT-model-extension"@en .

nedt:DTRun a owl:Class ;
    rdfs:label "DT Run"@en ;
    rdfs:comment "A single execution of the digital-twin notebook that produces a bundle of KPIValues. Uses prov:used / prov:generated / prov:wasDerivedFrom directly."@en ;
    rdfs:subClassOf prov:Activity ;
    nedt:layer "DT-model-extension"@en .

nedt:DwellingType a owl:Class ;
    rdfs:label "Dwelling Type"@en ;
    rdfs:comment "Structural dwelling type: detached, semi-detached, terrace, end-of-terrace, apartment."@en ;
    rdfs:subClassOf nedt:ArchetypeDescriptor ;
    nedt:layer "DT-model-extension"@en .

nedt:ExportedEnergy a owl:Class ;
    rdfs:label "Exported Energy"@en ;
    rdfs:comment "Annual PV energy exported to the grid (kWh)."@en ;
    rdfs:subClassOf nedt:KPIValue ;
    nedt:layer "DT-model-extension"@en .

nedt:LVAggregation a owl:Class ;
    rdfs:label "LV Aggregation Procedure"@en ;
    rdfs:comment "Procedure that sums archetype-level hourly load to the LV-station level via the hull-polygon assignment."@en ;
    rdfs:subClassOf ssn:Procedure ;
    nedt:layer "DT-model-extension"@en .

nedt:LoadMetric a owl:Class ;
    rdfs:label "Load Metric"@en ;
    rdfs:subClassOf ssn:ObservationValue ;
    nedt:layer "DT-model-extension"@en .

nedt:NationalKPI a owl:Class ;
    rdfs:label "National KPI"@en ;
    rdfs:comment "A KPI definition whose values are aggregated across all 26 counties."@en ;
    rdfs:subClassOf nedt:KPI ;
    nedt:layer "DT-model-extension"@en .

nedt:OperationalKPI a owl:Class ;
    rdfs:label "Operational KPI"@en ;
    rdfs:subClassOf nedt:KPI ;
    nedt:layer "DT-model-extension"@en .

nedt:ReversePowerFlowHour a owl:Class ;
    rdfs:label "Reverse Power-Flow Hour"@en ;
    rdfs:comment "An hour with negative net flow at the LV transformer (local PV generation exceeds local consumption)."@en ;
    nedt:layer "DT-model-extension"@en .

nedt:ScenarioAssumption a owl:Class ;
    rdfs:label "Scenario Assumption"@en ;
    rdfs:comment "A written or sourced assumption underpinning a scenario parameter (CAP, SEAI, internal expert judgement)."@en ;
    rdfs:subClassOf prov:Entity ;
    nedt:layer "DT-model-extension"@en .

nedt:SelfConsumptionRatio a owl:Class ;
    rdfs:label "Self-Consumption Ratio"@en ;
    rdfs:comment "Annual PV self-consumption as a fraction (0-1) of generation used on-site."@en ;
    rdfs:subClassOf nedt:KPIValue ;
    nedt:layer "DT-model-extension"@en .

nedt:SensitivityRun a owl:Class ;
    rdfs:label "Sensitivity Run"@en ;
    rdfs:comment "A parameter-sweep execution that ranks scenario parameters by their marginal effect on county peak and CO2."@en ;
    rdfs:subClassOf prov:Activity ;
    nedt:layer "DT-model-extension"@en .

nedt:TacticalKPI a owl:Class ;
    rdfs:label "Tactical KPI"@en ;
    rdfs:subClassOf nedt:KPI ;
    nedt:layer "DT-model-extension"@en .

nedt:adoptionFraction a owl:DatatypeProperty ;
    rdfs:comment "Fraction of eligible (non-apartment) dwellings that have PV installed." ;
    rdfs:domain nedt:PVAdoptionScenario ;
    rdfs:range xsd:decimal .

nedt:allocatedBy a owl:ObjectProperty ;
    rdfs:domain nedt:TransitionLedger ;
    rdfs:range nedt:LargestRemainderAlloc .

nedt:assemblesReport a owl:ObjectProperty ;
    rdfs:label "assembles report"@en ;
    rdfs:domain nedt:FigCollector ;
    rdfs:range nedt:HTMLReport .

nedt:attributedToEndUse a owl:ObjectProperty ;
    rdfs:label "attributed to end-use"@en ;
    rdfs:domain nedt:EndUseContribution ;
    rdfs:range nedt:EndUseLoad .

nedt:breachHours a owl:DatatypeProperty ;
    rdfs:label "breach hours per year"@en ;
    rdfs:domain nedt:ReinforcementNeed ;
    rdfs:range xsd:integer .

nedt:collectsChart a owl:ObjectProperty ;
    rdfs:label "collects chart"@en ;
    rdfs:domain nedt:FigCollector ;
    rdfs:range nedt:ChartJSChart .

nedt:collectsMap a owl:ObjectProperty ;
    rdfs:label "collects map"@en ;
    rdfs:domain nedt:FigCollector ;
    rdfs:range nedt:DeckGLMap .

nedt:computesDelta a owl:ObjectProperty ;
    rdfs:domain nedt:LoadCalculation ;
    rdfs:range nedt:DeltaSeries .

nedt:computesDensity a owl:ObjectProperty ;
    rdfs:domain nedt:LoadCalculation ;
    rdfs:range nedt:HeatDensity .

nedt:computesLoad a owl:ObjectProperty ;
    rdfs:domain nedt:LoadCalculation ;
    rdfs:range nedt:EnergyLoad .

nedt:contains a owl:ObjectProperty ;
    rdfs:domain nedt:County ;
    rdfs:range nedt:LVStation .

nedt:contributionPercent a owl:DatatypeProperty ;
    rdfs:label "contribution percent"@en ;
    rdfs:comment "Share 0-100 of the overload attributable to this end-use."@en ;
    rdfs:domain nedt:EndUseContribution ;
    rdfs:range xsd:decimal .

nedt:derivedFromGrant a owl:ObjectProperty ;
    rdfs:domain nedt:PVAdoptionScenario ;
    rdfs:range nedt:SEAIGrantRecord .

nedt:derivedUnder a owl:ObjectProperty ;
    rdfs:label "derived under scenario"@en ;
    rdfs:domain nedt:KPIValue ;
    rdfs:range nedt:Scenario .

nedt:eligibleBER a owl:DatatypeProperty ;
    rdfs:comment "All BER letters A–E admitted; no BER restriction in default deployment." ;
    rdfs:domain nedt:PVSystem ;
    rdfs:range xsd:string .

nedt:endUse a owl:DatatypeProperty ;
    rdfs:label "end-use"@en ;
    rdfs:comment "Enumerated end-use tag: space_heat | dhw | appliance | lighting | cooking | ev | hp_replace."@en ;
    rdfs:domain nedt:EndUseLoad ;
    rdfs:range xsd:string .

nedt:evaluatesCounty a owl:ObjectProperty ;
    rdfs:label "evaluates county"@en ;
    rdfs:domain nedt:KPIValue ;
    rdfs:range nedt:County .

nedt:evaluatesYear a owl:DatatypeProperty ;
    rdfs:label "evaluates year"@en ;
    rdfs:domain nedt:KPIValue ;
    rdfs:range xsd:gYear .

nedt:firstBreachYear a owl:DatatypeProperty ;
    rdfs:label "first breach year"@en ;
    rdfs:domain nedt:ReinforcementNeed ;
    rdfs:range xsd:gYear .

nedt:forArchetype a owl:ObjectProperty ;
    rdfs:label "for archetype"@en ;
    rdfs:domain nedt:ScenarioParameter ;
    rdfs:range nedt:Archetype .

nedt:forYear a owl:DatatypeProperty ;
    rdfs:label "for year"@en ;
    rdfs:domain nedt:ScenarioParameter ;
    rdfs:range xsd:gYear .

nedt:fromScenario a owl:ObjectProperty ;
    rdfs:label "from scenario"@en ;
    rdfs:domain nedt:StationTransition ;
    rdfs:range nedt:Scenario .

nedt:grantCount a owl:DatatypeProperty ;
    rdfs:domain nedt:SEAIGrantRecord ;
    rdfs:range xsd:integer .

nedt:grantFundingEUR a owl:DatatypeProperty ;
    rdfs:domain nedt:SEAIGrantRecord ;
    rdfs:range xsd:decimal .

nedt:grantYear a owl:DatatypeProperty ;
    rdfs:domain nedt:SEAIGrantRecord ;
    rdfs:range xsd:gYear .

nedt:hasArchetype a owl:ObjectProperty ;
    rdfs:domain nedt:County ;
    rdfs:range nedt:Archetype .

nedt:hasAssociatedKPI a owl:ObjectProperty ;
    rdfs:domain nedt:PerformanceGoal ;
    rdfs:range nedt:KPI .

nedt:hasAttribution a owl:ObjectProperty ;
    rdfs:domain nedt:OverloadedStation ;
    rdfs:range nedt:OverloadAttribution .

nedt:hasBERFallback a owl:ObjectProperty ;
    rdfs:domain nedt:Archetype ;
    rdfs:range nedt:BERFallbackRule .

nedt:hasBldgShare a owl:ObjectProperty ;
    rdfs:domain nedt:LVStation ;
    rdfs:range nedt:BuildingShare .

nedt:hasCO2 a owl:ObjectProperty ;
    rdfs:domain nedt:EnergyLoad ;
    rdfs:range nedt:CO2Emission .

nedt:hasCalculation a owl:ObjectProperty ;
    rdfs:domain nedt:KPI ;
    rdfs:range nedt:KPICalculation .

nedt:hasCapacity a owl:ObjectProperty ;
    rdfs:domain nedt:LVStation ;
    rdfs:range nedt:StationCapacity .

nedt:hasCapacityBin a owl:ObjectProperty ;
    rdfs:domain nedt:PVSystem ;
    rdfs:range nedt:PVCapacityBin .

nedt:hasCapacityMix a owl:ObjectProperty ;
    rdfs:domain nedt:PVAdoptionScenario ;
    rdfs:range nedt:PVCapacityMix .

nedt:hasChart a owl:ObjectProperty ;
    rdfs:domain nedt:HTMLReport ;
    rdfs:range nedt:ChartJSChart .

nedt:hasCount a owl:ObjectProperty ;
    rdfs:domain nedt:Archetype ;
    rdfs:range nedt:ArchetypeCount .

nedt:hasCountySummary a owl:ObjectProperty ;
    rdfs:label "has county summary"@en ;
    rdfs:domain nedt:County ;
    rdfs:range nedt:CountySummary .

nedt:hasDeckMap a owl:ObjectProperty ;
    rdfs:domain nedt:HTMLReport ;
    rdfs:range nedt:DeckGLMap .

nedt:hasDescriptor a owl:ObjectProperty ;
    rdfs:domain nedt:Archetype ;
    rdfs:range nedt:ArchetypeDescriptor .

nedt:hasDisaggregation a owl:ObjectProperty ;
    rdfs:domain nedt:StrategicKPI ;
    rdfs:range nedt:KPI .

nedt:hasDominantDriver a owl:ObjectProperty ;
    rdfs:label "has dominant driver"@en ;
    rdfs:domain nedt:OverloadAttribution ;
    rdfs:range nedt:DominantDriver .

nedt:hasEV a owl:ObjectProperty ;
    rdfs:domain nedt:ElectricLoad ;
    rdfs:range nedt:EVScenario .

nedt:hasElec a owl:ObjectProperty ;
    rdfs:domain nedt:EnergyLoad ;
    rdfs:range nedt:ElectricLoad .

nedt:hasEvalTimeStep a owl:ObjectProperty ;
    rdfs:domain nedt:KPICalculation ;
    rdfs:range time:Interval .

nedt:hasFuelComponent a owl:ObjectProperty ;
    rdfs:domain nedt:HeatDensityGDF ;
    rdfs:range nedt:HeatFuelComponent .

nedt:hasHP a owl:ObjectProperty ;
    rdfs:domain nedt:ElectricLoad ;
    rdfs:range nedt:HPScenario .

nedt:hasHeat a owl:ObjectProperty ;
    rdfs:domain nedt:EnergyLoad ;
    rdfs:range nedt:HeatLoad .

nedt:hasHull a owl:ObjectProperty ;
    rdfs:domain nedt:LVStation ;
    rdfs:range nedt:HullPolygon .

nedt:hasKPIDefinition a owl:DatatypeProperty ;
    rdfs:domain nedt:KPI ;
    rdfs:range xsd:string .

nedt:hasKPIEvaluatedObject a owl:ObjectProperty ;
    rdfs:domain nedt:KPI ;
    rdfs:range nedt:KPIEvaluatedObject .

nedt:hasLoad a owl:ObjectProperty ;
    rdfs:domain nedt:LVStation ;
    rdfs:range nedt:StationLoad .

nedt:hasMode a owl:ObjectProperty ;
    rdfs:domain nedt:EVScenario ;
    rdfs:range nedt:EVMode .

nedt:hasPVProfile a owl:ObjectProperty ;
    rdfs:domain nedt:PVSystem ;
    rdfs:range nedt:PVGenerationProfile .

nedt:hasPVSystem a owl:ObjectProperty ;
    rdfs:domain nedt:Archetype ;
    rdfs:range nedt:PVSystem .

nedt:hasPerformanceGoal a owl:ObjectProperty ;
    rdfs:domain nedt:Stakeholder ;
    rdfs:range nedt:PerformanceGoal .

nedt:hasProfileKey a owl:ObjectProperty ;
    rdfs:label "has profile key"@en ;
    rdfs:domain nedt:Archetype ;
    rdfs:range nedt:ProfileKey .

nedt:hasRiskTable a owl:ObjectProperty ;
    rdfs:label "has risk table"@en ;
    rdfs:domain nedt:Scenario ;
    rdfs:range nedt:RiskTable .

nedt:hasScenarioParameter a owl:ObjectProperty ;
    rdfs:label "has scenario parameter"@en ;
    rdfs:domain nedt:Scenario ;
    rdfs:range nedt:ScenarioParameter .

nedt:hasSections a owl:ObjectProperty ;
    rdfs:domain nedt:HTMLReport ;
    rdfs:range nedt:ReportSection .

nedt:hasStationTransition a owl:ObjectProperty ;
    rdfs:label "has station transition"@en ;
    rdfs:domain nedt:LVStation ;
    rdfs:range nedt:StationTransition .

nedt:hasStatus a owl:ObjectProperty ;
    rdfs:domain nedt:Utilisation ;
    rdfs:range nedt:UtilisationStatus .

nedt:hasTariff a owl:ObjectProperty ;
    rdfs:domain nedt:ElectricLoad ;
    rdfs:range nedt:Tariff .

nedt:hasTopTransitions a owl:ObjectProperty ;
    rdfs:label "has top transitions"@en ;
    rdfs:domain nedt:Scenario ;
    rdfs:range nedt:TopTransitions .

nedt:hasTransition a owl:ObjectProperty ;
    rdfs:domain nedt:Scenario ;
    rdfs:range nedt:HPTransition .

nedt:hasTransitionKey a owl:ObjectProperty ;
    rdfs:domain nedt:Archetype ;
    rdfs:range nedt:TransitionKey .

nedt:hasUtilisation a owl:ObjectProperty ;
    rdfs:domain nedt:LVStation ;
    rdfs:range nedt:Utilisation .

nedt:inCounty a owl:ObjectProperty ;
    rdfs:domain nedt:ArchetypeCount ;
    rdfs:range nedt:County .

nedt:installedCapacity_kWp a owl:DatatypeProperty ;
    rdfs:domain nedt:PVSystem ;
    rdfs:range xsd:decimal .

nedt:isProvidedBy a owl:ObjectProperty ;
    rdfs:domain nedt:DatumSource ;
    rdfs:range ssn:Observation .

nedt:layer a owl:AnnotationProperty ;
    rdfs:label "contribution layer"@en ;
    rdfs:comment "One of: 'core-KG-framework' (exists in the utility-aware KG of Hoare et al. 2026 and associated standard ontologies such as BOT / SARAGON / GeoDirectory / OSI) or 'DT-model-extension' (contributed by this National Energy Digital Twin)."@en .

nedt:listsStation a owl:ObjectProperty ;
    rdfs:label "lists overloaded station"@en ;
    rdfs:domain nedt:RiskTable ;
    rdfs:range nedt:OverloadedStation .

nedt:listsTransition a owl:ObjectProperty ;
    rdfs:label "lists station transition"@en ;
    rdfs:domain nedt:TopTransitions ;
    rdfs:range nedt:StationTransition .

nedt:modifies a owl:ObjectProperty ;
    rdfs:domain nedt:Scenario ;
    rdfs:range nedt:ArchetypeCount .

nedt:occursAt a owl:DatatypeProperty ;
    rdfs:label "occurs at"@en ;
    rdfs:domain nedt:OverloadEvent ;
    rdfs:range xsd:dateTime .

nedt:overloadMagnitude_kW a owl:DatatypeProperty ;
    rdfs:label "overload magnitude (kW)"@en ;
    rdfs:domain nedt:OverloadEvent ;
    rdfs:range xsd:decimal .

nedt:producesNetLoad a owl:ObjectProperty ;
    rdfs:domain nedt:NettingProcedure ;
    rdfs:range nedt:NetLoad .

nedt:ranksBy a owl:ObjectProperty ;
    rdfs:domain nedt:OverloadAttribution ;
    rdfs:range nedt:ContribRank .

nedt:recordsIn a owl:ObjectProperty ;
    rdfs:domain nedt:Scenario ;
    rdfs:range nedt:TransitionLedger .

nedt:resolvesTo a owl:ObjectProperty ;
    rdfs:label "resolves to profile"@en ;
    rdfs:domain nedt:ProfileKey ;
    rdfs:range nedt:NexsysProfile .

nedt:summarisesDensity a owl:ObjectProperty ;
    rdfs:label "summarises heat density"@en ;
    rdfs:domain nedt:CountySummary ;
    rdfs:range nedt:HeatDensityGDF .

nedt:toScenario a owl:ObjectProperty ;
    rdfs:label "to scenario"@en ;
    rdfs:domain nedt:StationTransition ;
    rdfs:range nedt:Scenario .

nedt:triggers a owl:ObjectProperty ;
    rdfs:domain nedt:Scenario ;
    rdfs:range nedt:OverloadedStation .

nedt:uptakeValue a owl:DatatypeProperty ;
    rdfs:label "uptake value"@en ;
    rdfs:comment "Numeric fraction in [0,1] for HP/EV uptake, or kWp for PV."@en ;
    rdfs:domain nedt:ScenarioParameter ;
    rdfs:range xsd:decimal .

nedt:usePalette a owl:ObjectProperty ;
    rdfs:domain nedt:HTMLReport ;
    rdfs:range nedt:ColourPalette .

nedt:usesBasemap a owl:ObjectProperty ;
    rdfs:domain nedt:DeckGLMap ;
    rdfs:range nedt:GeoLocation .

nedt:usesNexsys a owl:ObjectProperty ;
    rdfs:domain nedt:EnergyLoad ;
    rdfs:range nedt:NexsysProfile .

nedt:usesNoEVProfile a owl:ObjectProperty ;
    rdfs:domain nedt:EnergyLoad ;
    rdfs:range nedt:NexsysProfile .

nedt:usesProfile a owl:ObjectProperty ;
    rdfs:domain nedt:LoadCalculation ;
    rdfs:range nedt:HourlyProfile .

inst:KPI_AnnualCO2 a nedt:KPI ;
    rdfs:label "Annual CO2 Emissions" .

inst:KPI_PVSelfConsumption a nedt:KPI ;
    rdfs:label "PV Self-Consumption Rate" .

inst:KPI_PeakLVUtilisation a nedt:KPI ;
    rdfs:label "Peak LV Utilisation" .

inst:NexsysProfile_Bungalow_B_1_gasboiler a nedt:NexsysProfile ;
    rdfs:label "Nexsys·Bungalow_B_1_gasboiler" ;
    nedt:sourceFile "Nexsys data_to divyanshu/modified_V1H_results_dynamic/Bungalow_B_1_gasboiler.csv" .

